# ─────────────────────────────────────────────────────────────────────
# CellGenic Portal — Environment Variables
# File: .env.local (create this in root of your Next.js project)
# NEVER commit this file to GitHub
# ─────────────────────────────────────────────────────────────────────

# WordPress / WooCommerce site URL (no trailing slash)
NEXT_PUBLIC_WP_URL=https://navajowhite-kingfisher-114147.hostingersite.com
NEXT_PUBLIC_WC_URL=https://navajowhite-kingfisher-114147.hostingersite.com

# WooCommerce REST API Keys
# Get from: WooCommerce → Settings → Advanced → REST API → Add Key
WC_CONSUMER_KEY=ck_replace_with_your_key
WC_CONSUMER_SECRET=cs_replace_with_your_secret

# JWT Secret (must match JWT_AUTH_SECRET_KEY in wp-config.php)
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
